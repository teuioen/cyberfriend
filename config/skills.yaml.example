# Skills 配置模板 - 定义AI角色可以调用的自定义技能
# 复制为 config/skills.yaml 即可自动加载（无需在 app.yaml 中额外配置）

skills:
  # 示例技能：角色记忆强化（激活后会补充更多历史记忆上下文）
  - name: "记忆回溯"
    description: "回顾与用户的共同记忆，加深情感联结"
    prompt: |
      你现在正在仔细回忆与对方共同经历的美好时刻。
      请在接下来的回复中，自然地提及一两个具体的共同记忆，
      表达你对这段关系的珍视。
    enabled: true

  # 示例技能：开心聊天模式
  - name: "活泼模式"
    description: "切换到更活泼、更爱撒娇的说话风格"
    prompt: |
      现在请你表现得更加活泼开朗，语气更俏皮，
      可以适当使用颜文字和可爱的表达方式，
      但仍然保持你原本的个性底色。
    enabled: true

  # 示例技能：日记触发（激活后自动写一篇日记）
  - name: "写日记"
    description: "触发今日日记写作"
    actions:
      - '<DIARY_WRITE>今天又是充实的一天……</DIARY_WRITE>'
    enabled: false   # 默认禁用示例

  # 更多技能示例：
  # - name: "深度思考"
  #   description: "切换到更理性、分析性的思考模式"
  #   prompt: "请用更理性和有条理的方式分析当前情况，给出更深思熟虑的回复。"
  #
  # - name: "安慰模式"
  #   description: "进入温柔安慰模式，给予更多情感支持"
  #   prompt: "对方现在可能需要情感支持，请给予更多温暖和理解，聆听胜于建议。"
